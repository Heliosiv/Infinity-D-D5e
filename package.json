{
  "name": "infinity-dnd5e",
  "version": "0.2.22",
  "private": true,
  "description": "Dev tooling for the Infinity D&D5e Foundry module.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "check": "node scripts/run-checks.mjs",
    "check:roller": "node scripts/test-roller.mjs",
    "check:budget": "node scripts/test-budget.mjs",
    "check:tag-vocabulary": "node scripts/test-tag-vocabulary.mjs",
    "check:pack-shape": "node scripts/test-pack-shape.mjs",
    "generate:spell-scrolls": "node scripts/generate-spell-scrolls.mjs",
    "plan:images": "node scripts/plan-item-images.mjs",
    "art:jobs": "node scripts/art-pipeline.mjs jobs",
    "art:jobs:missing": "node scripts/art-pipeline.mjs jobs --missing-only",
    "art:generate:shared": "node scripts/run-art-generation.mjs shared",
    "art:generate:shared:dry": "node scripts/run-art-generation.mjs shared --dry-run",
    "art:generate:unique": "node scripts/run-art-generation.mjs unique",
    "art:generate:unique:dry": "node scripts/run-art-generation.mjs unique --dry-run",
    "art:validate": "node scripts/art-pipeline.mjs validate",
    "art:validate:present": "node scripts/art-pipeline.mjs validate --present-only",
    "art:absent": "node scripts/art-pipeline.mjs absent",
    "art:restore": "node scripts/art-pipeline.mjs restore",
    "art:apply": "node scripts/art-pipeline.mjs apply",
    "art:apply:present": "node scripts/art-pipeline.mjs apply --present-only",
    "art:check": "node scripts/art-pipeline.mjs check",
    "sound:generate": "node scripts/sound-pipeline.mjs generate",
    "sound:validate": "node scripts/sound-pipeline.mjs validate",
    "release": "node scripts/run-checks.mjs && node scripts/build-release.mjs",
    "release:nocheck": "node scripts/build-release.mjs",
    "ui:harness": "node scripts/render-ui-harness.mjs",
    "ui:audit": "node scripts/audit-ui-layout.mjs",
    "format": "node ./node_modules/prettier/bin/prettier.cjs --write \"scripts/**/*.{js,mjs}\" \"styles/**/*.css\" \"*.{json,md}\"",
    "format:check": "node ./node_modules/prettier/bin/prettier.cjs --check \"scripts/**/*.{js,mjs}\" \"styles/**/*.css\" \"*.{json,md}\""
  },
  "devDependencies": {
    "handlebars": "^4.7.9",
    "prettier": "^3.3.3"
  }
}
