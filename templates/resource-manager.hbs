{{!--
  Infinity D&D5e — Quartermaster (Resource Manager).
  GM-only. Configure what counts as food/water/light, set the party's
  environment, run daily upkeep, and review the last report.
--}}
<div class="rm-shell">
  <header class="rm-head">
    <div class="rm-head__title">
      <h2><i class="fa-solid fa-campground" aria-hidden="true"></i> Quartermaster</h2>
      <p class="rm-head__sub">Party supplies — food, water &amp; light.</p>
    </div>
    <div class="rm-head__actions">
      <button type="button" class="mw-btn mw-btn--primary" data-action="advanceDay" title="Run one day of foraging + consumption now">
        <i class="fa-solid fa-forward-step" aria-hidden="true"></i> Advance Day
      </button>
      <button type="button" class="mw-btn mw-btn--ghost mw-btn--icon" data-action="refresh" title="Refresh">
        <i class="fa-solid fa-rotate" aria-hidden="true"></i>
      </button>
      <button type="button" class="mw-btn mw-btn--ghost mw-btn--icon" data-action="resetConfig" title="Reset to defaults">
        <i class="fa-solid fa-rotate-left" aria-hidden="true"></i>
      </button>
    </div>
  </header>

  {{#unless isAuthoritative}}
  <p class="rm-note rm-note--warn"><i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i> Another GM is the active one — daily upkeep runs on their client.</p>
  {{/unless}}

  <p class="rm-note">Set where the party is, check supplies below, then <strong>Advance Day</strong> — or turn on Auto-run to do it automatically as in-game days pass.</p>

  <section class="rm-section rm-environment">
    <h3>Where is the party?</h3>
    <div class="rm-environment__row">
      <select class="mw-input" data-role="environment" aria-label="Current environment">
        {{#each environments}}
        <option value="{{id}}" {{#if selected}}selected{{/if}}>{{optionLabel}}</option>
        {{/each}}
      </select>
      <span class="rm-environment__status">
        {{#if currentEnvForageable}}
        <i class="fa-solid fa-leaf" aria-hidden="true"></i> Foraging open · DC {{currentEnvDc}}
        {{else}}
        <i class="fa-solid fa-ban" aria-hidden="true"></i> No foraging here
        {{/if}}
      </span>
    </div>
  </section>

  <section class="rm-section rm-options">
    <h3>Rules</h3>
    <div class="rm-options__grid">
      <label class="rm-toggle"><input type="checkbox" data-config-path="autoTrigger" {{#if autoTrigger}}checked{{/if}} /> Auto-run on day change</label>
      <label class="rm-toggle"><input type="checkbox" data-config-path="waterEnabled" {{#if waterEnabled}}checked{{/if}} /> Track water</label>
      <label class="rm-toggle"><input type="checkbox" data-config-path="halfRations" {{#if halfRations}}checked{{/if}} /> Half rations</label>
      <label class="rm-field">
        <span>Foraging yield</span>
        <select class="mw-input" data-config-path="forageMode">
          <option value="each" {{#if forageModeEach}}selected{{/if}}>Each forager keeps their own</option>
          <option value="best" {{#unless forageModeEach}}selected{{/unless}}>Best result feeds the party</option>
        </select>
      </label>
    </div>
  </section>

  <section class="rm-section rm-resources">
    <div class="rm-section__head">
      <h3>Tracked resources</h3>
      <button type="button" class="mw-btn mw-btn--ghost" data-action="addResource"><i class="fa-solid fa-plus" aria-hidden="true"></i> Add</button>
    </div>
    {{#each resources}}
    <article class="rm-resource">
      <div class="rm-resource__top">
        <input class="mw-input rm-resource__label" type="text" value="{{label}}" data-config-path="resource:{{id}}:label" aria-label="Resource name" />
        <label class="rm-resource__perday">Per day
          <input class="mw-input mw-input--num" type="number" min="0" step="1" value="{{perDay}}" data-config-path="resource:{{id}}:perDay" />
        </label>
        <label class="rm-resource__scope">Scope
          <select class="mw-input" data-config-path="resource:{{id}}:scope">
            <option value="per-character" {{#unless scopeIsParty}}selected{{/unless}}>Each character</option>
            <option value="party" {{#if scopeIsParty}}selected{{/if}}>Whole party</option>
          </select>
        </label>
        <button type="button" class="mw-btn mw-btn--ghost mw-btn--icon" data-action="removeResource" data-resource-id="{{id}}" title="Remove resource">
          <i class="fa-solid fa-trash" aria-hidden="true"></i>
        </button>
      </div>
      <div class="rm-resource__match">
        <label class="rm-field">
          <span>Name keywords (comma-separated)</span>
          <input class="mw-input" type="text" value="{{keywords}}" data-config-path="resource:{{id}}:keywords" placeholder="e.g. ration, rations" />
        </label>
        <label class="rm-field rm-field--narrow">
          <span>Tag (advanced)</span>
          <input class="mw-input" type="text" value="{{flagTag}}" data-config-path="resource:{{id}}:flagTag" title="Internal marker auto-applied to foraged/created items. Most GMs can leave this alone." />
        </label>
      </div>
      <div class="rm-resource__tags" data-drop-resource="{{id}}">
        <span class="rm-resource__droplabel"><i class="fa-solid fa-hand-pointer" aria-hidden="true"></i> Drag an item here (from a sheet or compendium) to match it exactly — more reliable than keywords.</span>
        <button type="button" class="mw-btn mw-btn--ghost mw-btn--icon" data-action="addTag" data-resource-id="{{id}}" title="Add an item by UUID (keyboard)"><i class="fa-solid fa-plus" aria-hidden="true"></i></button>
        {{#each tags}}
        <span class="rm-tag {{#if missing}}rm-tag--missing{{/if}}" title="{{uuid}}">{{name}}{{#if missing}} (missing){{/if}}
          <button type="button" class="rm-tag__x" data-action="removeTag" data-resource-id="{{../id}}" data-uuid="{{uuid}}" title="Remove this item">×</button>
        </span>
        {{/each}}
      </div>
    </article>
    {{/each}}
  </section>

  <section class="rm-section rm-party">
    <h3>Party supplies</h3>
    {{#if rosterIsImplicit}}
    <p class="rm-note">Auto-tracking every player-owned character. Mark a <strong>Stash</strong> or change <strong>Draws from</strong> to start curating the roster — or remove anyone who shouldn't be tracked.</p>
    {{/if}}
    {{#if hasRosterMembers}}
    <div class="rm-stash-pick">
      <label for="rm-party-stash">Food &amp; water stash</label>
      <select id="rm-party-stash" data-config-path="partyStashId" aria-label="Single stash the whole party draws food and water from">
        {{#each partyStashOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
      </select>
      {{#if partyStashActive}}<span class="rm-muted">Everyone draws food &amp; water from {{partyStashName}}'s pack.</span>{{else}}<span class="rm-muted">Or set each character's source per-row below.</span>{{/if}}
    </div>
    {{/if}}
    {{#if hasParty}}
    <table class="rm-table rm-roster">
      <thead>
        <tr>
          <th>Character</th>
          {{#each resources}}<th>{{label}}</th>{{/each}}
          <th>Exhaustion</th>
          <th title="This character's pack is a shared source the party can draw from">Stash</th>
          <th>Draws from</th>
          <th><span class="rm-sr">Remove</span></th>
        </tr>
      </thead>
      <tbody>
        {{#each partyRows}}
        <tr>
          <td>{{name}}</td>
          {{#each counts}}<td class="rm-num" title="{{detail}}">{{total}}</td>{{/each}}
          <td class="rm-num">{{exhaustion}}</td>
          <td class="rm-num">
            <input type="checkbox" data-config-path="roster:{{actorId}}:isStash" {{#if isStash}}checked{{/if}} aria-label="Mark {{name}} as a shared stash" />
          </td>
          <td class="rm-drawfrom">
            {{#if @root.partyStashActive}}
            <span class="rm-muted" title="The whole party draws food &amp; water from the party stash">→ {{@root.partyStashName}}</span>
            {{else if isStash}}
            <span class="rm-muted" title="A stash holds its own supplies">Self (stash)</span>
            {{else if canDrawFromStash}}
            <select data-config-path="roster:{{actorId}}:drawFrom" aria-label="Where {{name}} draws supplies from">
              {{#each drawFromOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
            </select>
            {{else}}
            <span class="rm-muted">Self</span>
            {{/if}}
          </td>
          <td>
            <button type="button" class="mw-btn mw-btn--ghost mw-btn--icon" data-action="removeRosterMember" data-actor-id="{{actorId}}" title="Remove {{name}} from the roster" aria-label="Remove {{name}} from the roster">×</button>
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    {{else}}
    <p class="rm-note">No player-owned characters found — assign a player as Owner on a character sheet and they'll appear here.</p>
    {{/if}}
    {{#if hasAvailableToAdd}}
    <div class="rm-roster-add">
      <select data-role="add-roster" aria-label="Character to add to the roster">
        {{#each availableToAdd}}<option value="{{id}}">{{name}}</option>{{/each}}
      </select>
      <button type="button" class="mw-btn mw-btn--ghost" data-action="addRosterMember"><i class="fa-solid fa-plus" aria-hidden="true"></i> Add character</button>
    </div>
    {{/if}}
  </section>

  {{#if report}}
  <section class="rm-section rm-report">
    <h3>Last upkeep — {{report.environmentLabel}}{{#if report.hasSuggestions}} · exhaustion suggested{{/if}}</h3>
    <ul class="rm-report__list">
      {{#each report.rows}}
      <li class="{{#if ok}}is-ok{{else}}is-short{{/if}}">
        <strong>{{name}}</strong>
        {{#if ok}}supplied{{else}}short {{shortFood}} food / {{shortWater}} water{{/if}}
        {{#if forageNote}} · {{forageNote}}{{/if}}
      </li>
      {{/each}}
      {{#if report.lightShortfall}}<li class="is-short">Light: {{report.lightShortfall}} short of torches</li>{{/if}}
    </ul>
  </section>
  {{/if}}
</div>
