{{!--
  Infinity D&D5e — Dashboard window template.
  Renders one section per tool category; each tile defers to the
  tool's own open() callback via the [data-action="launch"] hook.
--}}
<div class="id-shell">
  <header class="id-head">
    <div class="id-head__title">
      <h2>Infinity D&amp;D5e</h2>
      <p class="id-head__hint">Roll treasure, run shops, and track travel supplies — pick a tool below. Reopen this hub anytime with Shift+I.</p>
    </div>
    <div class="id-head__aside">
      <button
        type="button"
        class="id-head__help"
        data-action="help"
        title="How to use Infinity D&amp;D5e"
        aria-label="Help — how to use Infinity D&amp;D5e"
      >
        <i class="fa-solid fa-circle-question" aria-hidden="true"></i>
        <span>Help</span>
      </button>
      <span class="id-head__version">v{{moduleVersion}}</span>
    </div>
  </header>

  {{#if hasTools}}
  {{#if hasRecentTools}}
  <section class="id-section id-section--recent">
    <h3 class="id-section__title"><i class="fa-solid fa-clock-rotate-left" aria-hidden="true"></i> Recently Used</h3>
    <ul class="id-grid">
      {{#each recentTools}}
      <li class="id-tile">
        <button
          type="button"
          class="id-tile__btn"
          data-action="launch"
          data-tool-id="{{id}}"
          aria-label="{{title}}"
        >
          <span class="id-tile__icon" aria-hidden="true"><i class="{{icon}}"></i></span>
          <span class="id-tile__copy">
            <strong class="id-tile__title">{{title}}</strong>
            <span class="id-tile__desc">{{description}}</span>
          </span>
        </button>
      </li>
      {{/each}}
    </ul>
  </section>
  {{/if}}
  {{#each categories}}
  <section class="id-section">
    <h3 class="id-section__title">{{label}}</h3>
    <ul class="id-grid">
      {{#each tools}}
      <li class="id-tile {{#if isComingSoon}}is-disabled{{/if}}">
        <button
          type="button"
          class="id-tile__btn"
          data-action="launch"
          data-tool-id="{{id}}"
          aria-label="{{title}}{{#if statusLabel}} — {{statusLabel}}{{/if}}"
          {{#if isComingSoon}}aria-disabled="true" tabindex="-1"{{/if}}
        >
          <span class="id-tile__icon" aria-hidden="true"><i class="{{icon}}"></i></span>
          <span class="id-tile__copy">
            <strong class="id-tile__title">{{title}}</strong>
            <span class="id-tile__desc">{{description}}</span>
            {{#if statusLabel}}<span class="id-tile__badge">{{statusLabel}}</span>{{/if}}
          </span>
        </button>
      </li>
      {{/each}}
    </ul>
  </section>
  {{/each}}
  {{else}}
  <p class="id-empty">No tools registered yet.</p>
  {{/if}}

  <footer class="id-foot">
    <button type="button" class="id-foot__btn" data-action="openSettings" title="Open this module's settings (loot, merchants, sounds, travel & more)">
      <i class="fa-solid fa-sliders" aria-hidden="true"></i>
      <span>Module Settings</span>
    </button>
  </footer>
</div>
