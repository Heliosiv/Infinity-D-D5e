{{!--
  Infinity D&D5e — Per-Creature Loot window template.
  A roster of creatures (name + tier each); the Generate button rolls
  a small bundle per creature. Result is grouped per-creature with
  per-card reroll buttons.
--}}
<div class="pc-shell">
  <form class="pc-form" data-form="per-creature-loot" autocomplete="off">
    <header class="pc-form__head">
      <div>
        <h2 class="pc-form__title">Per-Creature Loot</h2>
        <p class="pc-form__hint">
          Add a creature per body in the fight. Each rolls its own small bundle, scaled by its tier.
        </p>
      </div>
      <div class="pc-form__budget" aria-live="polite">
        <span class="pc-form__budget-label">Total Treasure</span>
        <strong data-roster-budget>{{rosterTotalBudgetLabel}}</strong>
        <span class="pc-form__budget-sub" data-candidates>{{candidateLabel}}</span>
      </div>
      {{> toolMenu}}
    </header>

    {{!-- Roster --}}
    <fieldset class="lf-fieldset pc-roster">
      <legend class="lf-fieldset__legend">
        Roster
        <span class="lf-chiprow__bulk">
          <button type="button" class="lf-bulk" data-action="addCreature" {{#if rosterFull}}disabled{{/if}}>+ Creature</button>
          <button type="button" class="lf-bulk" data-action="addFive" {{#if rosterFull}}disabled{{/if}}>+ 5</button>
          <button type="button" class="lf-bulk" data-action="clearRoster">Clear</button>
        </span>
      </legend>
      {{#if rosterRows.length}}
      <ul class="pc-roster__list">
        {{#each rosterRows}}
        <li class="pc-roster__row">
          <input
            class="lf-input pc-roster__name"
            type="text"
            name="creatureName"
            data-creature-id="{{id}}"
            value="{{name}}"
            maxlength="40"
            aria-label="Creature name"
          />
          <div class="pc-roster__tiers" role="group" aria-label="Tier">
            {{#each tierOptions}}
            <button
              type="button"
              class="pc-roster__tier {{#if selected}}is-active{{/if}}"
              data-action="setCreatureTier"
              data-creature-id="{{../id}}"
              data-value="{{value}}"
              title="Set tier to {{label}}"
            >{{label}}</button>
            {{/each}}
          </div>
          <span class="pc-roster__budget" title="Per-creature gp budget">{{budgetLabel}}</span>
          <button
            type="button"
            class="pc-roster__remove"
            data-action="removeCreature"
            data-creature-id="{{id}}"
            title="Remove this creature"
            aria-label="Remove this creature"
          ><i class="fa-solid fa-xmark" aria-hidden="true"></i></button>
        </li>
        {{/each}}
      </ul>
      {{else}}
      <p class="pc-roster__empty">Roster is empty. Click <strong>+ Creature</strong> to add one.</p>
      {{/if}}
    </fieldset>

    {{!-- Sliders --}}
    <div class="lf-form__sliders">
      {{> pcSlider itemsPerCreature}}
      {{> pcSlider magicBias}}
    </div>

    {{!-- Rarity chips --}}
    <fieldset class="lf-fieldset">
      <legend class="lf-fieldset__legend">
        Rarity <small>(empty = all)</small>
        <span class="lf-chiprow__bulk">
          <button type="button" class="lf-bulk" data-action="chipAll" data-group="rarity">All</button>
          <button type="button" class="lf-bulk" data-action="chipNone" data-group="rarity">None</button>
        </span>
      </legend>
      <div class="lf-chiprow">
        {{#each rarityOptions}}
        <label class="lf-chip lf-chip--rarity-{{value}}">
          <input type="checkbox" name="rarity" value="{{value}}" {{#if selected}}checked{{/if}} />
          <span>{{label}}{{#if count}} <em class="lf-chip__count">{{count}}</em>{{/if}}</span>
        </label>
        {{/each}}
      </div>
    </fieldset>

    {{!-- Loot type chips --}}
    <fieldset class="lf-fieldset">
      <legend class="lf-fieldset__legend">
        Item Types <small>(empty = all)</small>
        <span class="lf-chiprow__bulk">
          <button type="button" class="lf-bulk" data-action="chipAll" data-group="lootType">All</button>
          <button type="button" class="lf-bulk" data-action="chipNone" data-group="lootType">None</button>
        </span>
      </legend>
      <div class="lf-chiprow">
        {{#each lootTypeOptions}}
        <label class="lf-chip">
          <input type="checkbox" name="lootType" value="{{value}}" {{#if selected}}checked{{/if}} />
          <span>{{label}}{{#if count}} <em class="lf-chip__count">{{count}}</em>{{/if}}</span>
        </label>
        {{/each}}
      </div>
    </fieldset>

    {{> marketFilter}}

    <div class="lf-form__actions">
      <button type="button" class="lf-btn lf-btn--primary" data-action="generate" title="Roll All (Enter or R)" {{#if loadingItems}}disabled aria-busy="true"{{/if}}{{#if noCandidates}} disabled{{/if}}>
        <i class="fa-solid fa-dice" aria-hidden="true"></i>
        <span>Roll All</span>
      </button>
      <button type="button" class="lf-btn lf-btn--ghost" data-action="reset" title="Restore form defaults">
        <i class="fa-solid fa-rotate-left" aria-hidden="true"></i>
        <span>Reset Settings</span>
      </button>
      {{#if hasResult}}
      <button type="button" class="lf-btn lf-btn--ghost" data-action="clear" title="Clear results, keep settings">
        <i class="fa-solid fa-eraser" aria-hidden="true"></i>
        <span>Clear Results</span>
      </button>
      {{/if}}
    </div>
  </form>

  <section class="pc-result" aria-live="polite">
    {{#if loadingItems}}
    <div class="lf-result__loading" role="status">
      <span class="lf-skeleton lf-skeleton--lg"></span>
      <span class="lf-skeleton"></span>
      <span class="lf-skeleton lf-skeleton--sm"></span>
      <p class="lf-result__placeholder">Loading items…</p>
    </div>
    {{else if hasResult}}
    <header class="lf-result__head">
      <h3 class="lf-result__title">
        Grand total — {{result.grandTotalLabel}} across {{result.creatures.length}} creature(s)
      </h3>
      <div class="lf-result__actions">
        <button type="button" class="lf-btn lf-btn--small" data-action="depositHaul" title="Give every creature's drops to one character">
          <i class="fa-solid fa-share-from-square" aria-hidden="true"></i>
          <span>Give to Character</span>
        </button>
        <button type="button" class="lf-btn lf-btn--small" data-action="sendToChat" title="Post this haul to chat">
          <i class="fa-solid fa-comment-dots" aria-hidden="true"></i>
          <span>Send to Chat</span>
        </button>
        <button type="button" class="lf-btn lf-btn--small" data-action="copyToClipboard" title="Copy a plain-text summary to the clipboard">
          <i class="fa-solid fa-clipboard" aria-hidden="true"></i>
          <span>Copy</span>
        </button>
        <button type="button" class="lf-btn lf-btn--small" data-action="distributeSplit" title="Split all drops across multiple characters">
          <i class="fa-solid fa-users" aria-hidden="true"></i>
          <span>Split</span>
        </button>
        <button type="button" class="lf-btn lf-btn--small" data-action="distributeToSelected" title="Split all drops across the selected canvas tokens' characters">
          <i class="fa-solid fa-bullseye" aria-hidden="true"></i>
          <span>To Selected</span>
        </button>
        <button type="button" class="lf-btn lf-btn--small" data-action="exportJournal" title="Save this haul to a journal entry">
          <i class="fa-solid fa-book" aria-hidden="true"></i>
          <span>Journal</span>
        </button>
      </div>
    </header>

    <div class="lf-result__search">
      <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
      <input type="search" class="lf-input" data-result-search placeholder="Filter drops…" aria-label="Filter drops by name or rarity" />
      <span class="lf-result__search-count" data-search-count aria-live="polite"></span>
    </div>

    <div class="pc-result__creatures">
      {{#each result.creatures}}
      <article class="pc-creature" style="--lf-stagger: {{@index}}">
        <header class="pc-creature__head">
          <div class="pc-creature__title">
            <strong>{{name}}</strong>
            <span class="pc-creature__tier">{{tierLabel}}</span>
          </div>
          <div class="pc-creature__right">
            <span class="pc-creature__total">{{totalGpLabel}}</span>
            {{#if budgetLabel}}<span class="pc-creature__budget-hint" title="Per-creature gp budget">/ {{budgetLabel}}</span>{{/if}}
            <button
              type="button"
              class="pc-creature__reroll"
              data-action="rerollCreature"
              data-creature-id="{{id}}"
              title="Re-roll this creature's drops"
              aria-label="Re-roll this creature"
            ><i class="fa-solid fa-rotate" aria-hidden="true"></i></button>
          </div>
        </header>
        {{#if items.length}}
        <ul class="pc-creature__items">
          {{#each items}}
          {{> lootItem}}
          {{/each}}
        </ul>
        {{else}}
        <p class="pc-creature__empty">No drops for this creature.</p>
        {{/if}}
      </article>
      {{/each}}
    </div>
    {{else}}
    <p class="lf-result__placeholder">
      Build a roster and click <strong>Roll All</strong>.
    </p>
    {{/if}}
  </section>
</div>

{{!-- Reusable slider partial --}}
{{#*inline "pcSlider"}}
<div class="lf-slider">
  <div class="lf-slider__head">
    <label class="lf-slider__label" for="pc-slider-{{name}}">{{label}}</label>
    <span class="lf-slider__value">
      <strong data-readout="{{name}}">{{valueLabel}}</strong>
      {{#if presetLabel}}<em data-preset="{{name}}">{{presetLabel}}</em>{{/if}}
    </span>
  </div>
  <input
    class="lf-slider__input"
    id="pc-slider-{{name}}"
    type="range"
    name="{{name}}"
    min="{{min}}"
    max="{{max}}"
    step="{{step}}"
    value="{{value}}"
  />
  {{#if snaps}}
  <div class="lf-slider__snaps">
    {{#each snaps}}
    <button
      type="button"
      class="lf-slider__snap {{#if active}}is-active{{/if}}"
      data-action="snap"
      data-target="{{../name}}"
      data-value="{{value}}"
    >{{label}}</button>
    {{/each}}
  </div>
  {{/if}}
</div>
{{/inline}}

{{!-- Shared result-item row (see loot-forge.hbs for the canonical copy). --}}
{{#*inline "lootItem"}}
<li
  class="lf-result__item lf-result__item--{{rarity}} {{#if locked}}is-locked{{/if}}"
  style="--lf-stagger: {{@index}}"
  draggable="true"
  data-result-item
  data-draggable-result-id
  data-entry-id="{{entryId}}"
  data-result-id="{{entryId}}"
  data-uuid="{{item.uuid}}"
  data-search-text="{{displayName}} {{rarity}}"
  title="Double-click to open sheet"
>
  <button type="button" class="lf-result__open" data-action="openItem" data-uuid="{{item.uuid}}" title="Open item sheet">
    <img class="lf-result__icon" src="{{imageSrc}}" alt="" loading="lazy" data-result-image data-fallback-src="icons/svg/item-bag.svg" />
    <div class="lf-result__copy">
      <strong class="lf-result__name">{{displayName}}</strong>
      {{#if variantSummary}}<span class="lf-result__variant">{{variantSummary}}</span>{{/if}}
      {{#if sourceLabel}}<span class="lf-result__source">{{sourceLabel}}</span>{{/if}}
      <span class="lf-result__meta">{{quantityLabel}}{{rarity}} · {{gpTotalLabel}}{{#if valueLabel}} · {{valueLabel}}{{/if}}</span>
    </div>
  </button>
  <div class="lf-result__controls">
    {{#unless variant}}
    <button type="button" class="lf-result__ctrl" data-action="itemQtyDec" data-entry-id="{{entryId}}" title="Fewer" aria-label="Decrease quantity"><i class="fa-solid fa-minus" aria-hidden="true"></i></button>
    <button type="button" class="lf-result__ctrl" data-action="itemQtyInc" data-entry-id="{{entryId}}" title="More" aria-label="Increase quantity"><i class="fa-solid fa-plus" aria-hidden="true"></i></button>
    {{/unless}}
    <button type="button" class="lf-result__ctrl" data-action="rerollOne" data-entry-id="{{entryId}}" title="Re-roll just this item" aria-label="Re-roll this item"><i class="fa-solid fa-rotate" aria-hidden="true"></i></button>
    <button type="button" class="lf-result__ctrl" data-action="distributeOne" data-entry-id="{{entryId}}" title="Send to one actor" aria-label="Send to actor"><i class="fa-solid fa-paper-plane" aria-hidden="true"></i></button>
    <button type="button" class="lf-result__ctrl lf-result__ctrl--danger" data-action="deleteItem" data-entry-id="{{entryId}}" title="Remove this item" aria-label="Remove item"><i class="fa-solid fa-trash" aria-hidden="true"></i></button>
  </div>
</li>
{{/inline}}

{{!-- Presets + history + undo menu (see loot-forge.hbs for canonical copy). --}}
{{#*inline "toolMenu"}}
<details class="lf-menu">
  <summary class="lf-menu__trigger" title="Presets, recent rolls & undo" aria-label="Presets and history menu">
    <i class="fa-solid fa-ellipsis-vertical" aria-hidden="true"></i>
  </summary>
  <div class="lf-menu__panel">
    <div class="lf-menu__row">
      <input type="text" class="lf-input lf-menu__name" data-preset-name placeholder="Preset name…" aria-label="New preset name" maxlength="40" />
      <button type="button" class="lf-btn lf-btn--small" data-action="savePreset" title="Save current settings as a preset">
        <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i><span>Save</span>
      </button>
      <button type="button" class="lf-btn lf-btn--small lf-menu__io" data-action="exportPresets" title="Download all presets as a JSON file" aria-label="Export presets">
        <i class="fa-solid fa-file-export" aria-hidden="true"></i>
      </button>
      <button type="button" class="lf-btn lf-btn--small lf-menu__io" data-action="importPresets" title="Import presets from a JSON file" aria-label="Import presets">
        <i class="fa-solid fa-file-import" aria-hidden="true"></i>
      </button>
    </div>
    {{#if hasPresets}}
    <div class="lf-menu__heading">Presets</div>
    <ul class="lf-menu__list">
      {{#each presets}}
      <li class="lf-menu__item">
        <button type="button" class="lf-menu__load" data-action="loadPreset" data-preset-id="{{id}}" title="Load this preset">{{name}}</button>
        <button type="button" class="lf-menu__del" data-action="deletePreset" data-preset-id="{{id}}" title="Delete this preset" aria-label="Delete preset"><i class="fa-solid fa-trash" aria-hidden="true"></i></button>
      </li>
      {{/each}}
    </ul>
    {{/if}}
    {{#if hasHistory}}
    <div class="lf-menu__heading">Recent rolls</div>
    <ul class="lf-menu__list">
      {{#each history}}
      <li class="lf-menu__item">
        <button type="button" class="lf-menu__load" data-action="loadHistory" data-history-id="{{id}}" title="Reopen this roll">{{label}}</button>
      </li>
      {{/each}}
    </ul>
    <button type="button" class="lf-btn lf-btn--small lf-menu__clear" data-action="clearHistory" title="Forget every recent roll">
      <i class="fa-solid fa-trash" aria-hidden="true"></i><span>Clear History</span>
    </button>
    {{/if}}
    {{#if canUndo}}
    <button type="button" class="lf-btn lf-btn--small lf-menu__undo" data-action="undo" title="Undo the last item change">
      <i class="fa-solid fa-rotate-left" aria-hidden="true"></i><span>Undo</span>
    </button>
    {{/if}}
  </div>
</details>
{{/inline}}

{{!-- Item value filter (see loot-forge.hbs for the canonical copy). --}}
{{#*inline "marketFilter"}}
<fieldset class="lf-fieldset lf-market-filter">
  <legend class="lf-fieldset__legend">
    Item Value <small>(market tier or custom range)</small>
    <span class="lf-chiprow__bulk"><strong data-value-range>{{valueRangeLabel}}</strong></span>
  </legend>
  <div class="lf-market">
    {{#each marketTiers}}
    <button
      type="button"
      class="lf-market__tier {{#if active}}is-active{{/if}}"
      data-action="marketTier"
      data-min="{{min}}"
      data-max="{{max}}"
      title="{{label}} — {{#if max}}items up to {{max}} gp{{else}}no value limit{{/if}}"
    >
      <i class="{{icon}}" aria-hidden="true"></i>
      <span>{{label}}</span>
    </button>
    {{/each}}
  </div>
  <div class="lf-market__range">
    <label class="lf-field lf-field--inline">
      <span class="lf-field__label">Min gp <small>(0 = none)</small></span>
      <input class="lf-input" type="number" name="minItemGp" min="0" step="50" value="{{minItemGp}}" />
    </label>
    <label class="lf-field lf-field--inline">
      <span class="lf-field__label">Max gp <small>(0 = none)</small></span>
      <input class="lf-input" type="number" name="maxItemGp" min="0" step="50" value="{{maxItemGp}}" />
    </label>
  </div>
</fieldset>
{{/inline}}
