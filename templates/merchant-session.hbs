{{!--
  Infinity D&D5e — Merchant Session template.
  Pushed to a player's client when the GM opens a session. Player
  browses, bargains, buys, sells.
--}}
<div class="ms-shell">
  <header class="ms-head">
    <span class="ms-head__art" style="background-image:url('{{merchant.art}}');" aria-hidden="true"></span>
    <div class="ms-head__title">
      <h2>{{merchant.name}}</h2>
      {{#if merchant.description}}
      <p class="ms-head__desc">{{merchant.description}}</p>
      {{/if}}
      {{#if merchantGoldLabel}}<span class="ms-head__coffer"><i class="fa-solid fa-vault" aria-hidden="true"></i> Shop Gold: {{merchantGoldLabel}}</span>{{/if}}
    </div>
    <div class="ms-head__purse">
      <span class="ms-head__purse-label">Your Gold</span>
      <strong class="ms-head__purse-value">{{walletLabel}}</strong>
    </div>
  </header>

  {{#if previewMode}}
  <div class="ms-preview-banner" role="note">
    <i class="fa-solid fa-eye" aria-hidden="true"></i>
    <span>Preview — nothing real changes. Buy, sell &amp; bargain are simulated and logged{{#if previewNoActor}}; pick a character when opening to try selling or bargaining{{/if}}.</span>
  </div>
  {{/if}}

  <nav class="ms-tabs" role="tablist">
    <button type="button" class="ms-tab {{#if buyActive}}is-active{{/if}}" data-action="tab" data-tab="buy" role="tab">
      <i class="fa-solid fa-cart-shopping" aria-hidden="true"></i> Buy
    </button>
    <button type="button" class="ms-tab {{#if sellActive}}is-active{{/if}}" data-action="tab" data-tab="sell" role="tab">
      <i class="fa-solid fa-coins" aria-hidden="true"></i> Sell
    </button>
  </nav>

  {{#if buyActive}}
  <section class="ms-rows" aria-label="Goods for sale">
    {{#if buyRows.length}}
      {{#each buyRows}}
      <article class="ms-row {{#if rarity}}ms-row--{{rarity}}{{/if}} {{#if outOfStock}}is-out{{/if}} {{#if missing}}is-missing{{/if}}" data-uuid="{{uuid}}" title="Double-click to open sheet">
        <span class="ms-row__icon" style="background-image:url('{{img}}');" aria-hidden="true"></span>
        <div class="ms-row__copy">
          <strong class="ms-row__name">{{name}}</strong>
          <span class="ms-row__meta">
            {{#if rarityLabel}}<span class="ms-rarity ms-rarity--{{rarity}}">{{rarityLabel}}</span>{{/if}}
            {{stockLabel}}
            {{#if sealLabel}}<span class="ms-seal" title="Bargained price">{{sealLabel}}</span>{{/if}}
            {{#if cannotBuyReason}}<span class="ms-row__warn">{{cannotBuyReason}}</span>{{/if}}
          </span>
        </div>
        <div class="ms-row__price">
          {{#if priceDeltaLabel}}
          <span class="ms-row__base">{{baseLabel}}</span>
          <strong class="ms-row__final"><i class="fa-solid fa-coins ms-coin" aria-hidden="true"></i>{{finalLabel}}</strong>
          <span class="ms-row__delta {{deltaClass}}">{{priceDeltaLabel}}</span>
          {{else}}
          <strong class="ms-row__final"><i class="fa-solid fa-coins ms-coin" aria-hidden="true"></i>{{finalLabel}}</strong>
          {{/if}}
        </div>
        <div class="ms-row__actions">
          <button type="button" class="mw-btn mw-btn--ghost mw-btn--icon" data-action="bargainBuy" data-uuid="{{uuid}}" {{#if bargainLocked}}disabled{{/if}} title="Bargain (one attempt per item)">
            <i class="fa-solid fa-comments-dollar" aria-hidden="true"></i>
          </button>
          <button type="button" class="mw-btn" data-action="buyOne" data-uuid="{{uuid}}" {{#if cannotBuy}}disabled{{/if}}>
            Buy 1
          </button>
          <input class="mw-input mw-input--num" type="number" data-role="buyQty" data-uuid="{{uuid}}" min="1" max="{{maxQty}}" value="1" {{#if cannotBuy}}disabled{{/if}} title="Quantity to buy" />
          <button type="button" class="mw-btn mw-btn--primary" data-action="buyN" data-uuid="{{uuid}}" {{#if cannotBuy}}disabled{{/if}}>
            Buy
          </button>
        </div>
      </article>
      {{/each}}
    {{else}}
      <p class="mw-empty">This merchant has nothing on display.</p>
    {{/if}}
  </section>
  {{/if}}

  {{#if sellActive}}
  <section class="ms-rows" aria-label="Your sellable items">
    {{#if sellRows.length}}
      {{#each sellRows}}
      <article class="ms-row {{#if rarity}}ms-row--{{rarity}}{{/if}}" data-item-id="{{itemId}}" data-uuid="{{uuid}}" title="Double-click to open sheet">
        <span class="ms-row__icon" style="background-image:url('{{img}}');" aria-hidden="true"></span>
        <div class="ms-row__copy">
          <strong class="ms-row__name">{{name}}</strong>
          <span class="ms-row__meta">
            {{#if rarityLabel}}<span class="ms-rarity ms-rarity--{{rarity}}">{{rarityLabel}}</span>{{/if}}
            You have {{ownedQty}}
            {{#if sealLabel}}<span class="ms-seal" title="Bargained payout">{{sealLabel}}</span>{{/if}}
            {{#if cannotSell}}<span class="ms-row__warn">merchant low on gold</span>{{/if}}
          </span>
        </div>
        <div class="ms-row__price">
          {{#if priceDeltaLabel}}
          <span class="ms-row__base">{{baseLabel}}</span>
          <strong class="ms-row__final"><i class="fa-solid fa-coins ms-coin" aria-hidden="true"></i>{{finalLabel}}</strong>
          <span class="ms-row__delta {{deltaClass}}">{{priceDeltaLabel}}</span>
          {{else}}
          <strong class="ms-row__final"><i class="fa-solid fa-coins ms-coin" aria-hidden="true"></i>{{finalLabel}}</strong>
          {{/if}}
        </div>
        <div class="ms-row__actions">
          <button type="button" class="mw-btn mw-btn--ghost mw-btn--icon" data-action="bargainSell" data-item-id="{{itemId}}" {{#if bargainLocked}}disabled{{/if}} title="Bargain">
            <i class="fa-solid fa-comments-dollar" aria-hidden="true"></i>
          </button>
          <button type="button" class="mw-btn" data-action="sellOne" data-item-id="{{itemId}}" {{#if cannotSell}}disabled{{/if}}>Sell 1</button>
          <input class="mw-input mw-input--num" type="number" data-role="sellQty" data-item-id="{{itemId}}" min="1" max="{{maxSellQty}}" value="1" title="Quantity to sell" {{#if cannotSell}}disabled{{/if}} />
          <button type="button" class="mw-btn mw-btn--primary" data-action="sellN" data-item-id="{{itemId}}" {{#if cannotSell}}disabled{{/if}}>Sell</button>
        </div>
      </article>
      {{/each}}
    {{else}}
      {{#if noActor}}
      <p class="mw-empty">No character to sell from{{#if previewMode}} — pick one when opening the preview{{else}} — ask your GM to assign you a character{{/if}}.</p>
      {{else}}
      <p class="mw-empty">No sellable items on your sheet.</p>
      {{/if}}
    {{/if}}
  </section>
  {{/if}}

  {{#if log.length}}
  <footer class="ms-log" aria-label="Transaction log">
    <h4>This session{{#if sessionSpentLabel}} · spent {{sessionSpentLabel}}{{/if}}{{#if sessionEarnedLabel}} · earned {{sessionEarnedLabel}}{{/if}}</h4>
    <ul>
      {{#each log}}
      <li class="{{kind}}">{{text}}</li>
      {{/each}}
    </ul>
  </footer>
  {{/if}}
</div>
