{{!--
  Infinity D&D5e — Merchant Workspace template.
  GM curation UI: list of merchants on the left, selected merchant
  editor + inventory grid + session-launch controls on the right.
--}}
<div class="mw-shell">
  <header class="mw-head">
    <div class="mw-head__title">
      <h2>Merchant Workspace</h2>
      <p class="mw-head__hint">
        Curate merchants once. Open a session for a specific player when they're ready to shop —
        their client pops a buy/sell window automatically.
      </p>
    </div>
    <div class="mw-head__actions">
      <button type="button" class="mw-btn mw-btn--primary" data-action="newMerchant" title="Create a new merchant">
        <i class="fa-solid fa-plus" aria-hidden="true"></i> New Merchant
      </button>
    </div>
  </header>

  <div class="mw-body">
    {{!-- Left rail: merchant list --}}
    <aside class="mw-list" aria-label="Merchants">
      {{#if hasMerchants}}
        <ul class="mw-list__items">
          {{#each merchants}}
          <li class="mw-list__row {{#if selected}}is-selected{{/if}}">
            <button type="button" class="mw-list__btn" data-action="selectMerchant" data-merchant-id="{{id}}">
              <span class="mw-list__art" style="background-image:url('{{art}}');" aria-hidden="true"></span>
              <span class="mw-list__copy">
                <strong class="mw-list__name">{{name}}</strong>
                <span class="mw-list__meta">{{itemCount}} item{{#unless itemCountIsOne}}s{{/unless}} · {{allowedCount}} player{{#unless allowedCountIsOne}}s{{/unless}}</span>
              </span>
            </button>
          </li>
          {{/each}}
        </ul>
      {{else}}
        <p class="mw-empty">No merchants yet. Click <strong>New Merchant</strong> to start.</p>
      {{/if}}
    </aside>

    {{!-- Right pane: editor --}}
    <section class="mw-edit" aria-label="Merchant editor">
      {{#if selected}}
      <form class="mw-form" data-form="merchant-edit" autocomplete="off">
        <div class="mw-form__head">
          <span class="mw-form__art" style="background-image:url('{{selected.art}}');" aria-hidden="true"></span>
          <div class="mw-form__head-fields">
            <label class="mw-field">
              <span class="mw-field__label">Name</span>
              <input class="mw-input" type="text" name="name" value="{{selected.name}}" />
            </label>
            <label class="mw-field">
              <span class="mw-field__label">Art</span>
              <div class="mw-field__row">
                <input class="mw-input" type="text" name="art" value="{{selected.art}}" placeholder="icons/svg/shop.svg" />
                <button type="button" class="mw-btn mw-btn--icon" data-action="pickArt" title="Browse or upload an image">
                  <i class="fa-solid fa-image" aria-hidden="true"></i>
                </button>
              </div>
            </label>
          </div>
        </div>

        <label class="mw-field">
          <span class="mw-field__label">Description / Flavor</span>
          <textarea class="mw-textarea" name="description" rows="2" placeholder="Optional flavor text shown to players.">{{selected.description}}</textarea>
        </label>

        <div class="mw-form__grid">
          <label class="mw-field">
            <span class="mw-field__label">Buy Price ×</span>
            <input class="mw-input" type="number" name="defaultMarkup" min="0.1" max="5" step="0.05" value="{{selected.defaultMarkup}}" />
          </label>
          <label class="mw-field">
            <span class="mw-field__label">Sell-Back ×</span>
            <input class="mw-input" type="number" name="sellRatio" min="0" max="1.5" step="0.05" value="{{selected.sellRatio}}" />
          </label>
          <label class="mw-field">
            <span class="mw-field__label">Bargain DC</span>
            <input class="mw-input" type="number" name="bargainDC" min="5" max="30" step="1" value="{{selected.bargainDC}}" />
          </label>
          <label class="mw-field mw-field--toggle">
            <span class="mw-field__label">Advantage on Bargain</span>
            <input type="checkbox" name="bargainAdvantage" {{#if selected.bargainAdvantage}}checked{{/if}} />
          </label>
          <label class="mw-field">
            <span class="mw-field__label">Gold on Hand</span>
            <input class="mw-input" type="number" name="goldOnHand" min="0" step="1" value="{{selected.goldOnHand}}" placeholder="∞ unlimited" />
          </label>
          <label class="mw-field">
            <span class="mw-field__label">Discount if Bargain Succeeds</span>
            <input class="mw-input" type="number" name="bargainSuccessPct" min="0" max="100" step="1" value="{{selected.bargainSuccessPct}}" />
          </label>
          <label class="mw-field">
            <span class="mw-field__label">Penalty if Bargain Fails</span>
            <input class="mw-input" type="number" name="bargainFailPct" min="0" max="100" step="1" value="{{selected.bargainFailPct}}" />
          </label>
        </div>

        <fieldset class="mw-fieldset">
          <legend>Allowed Skills</legend>
          <div class="mw-chiprow">
            {{#each skillOptions}}
            <label class="mw-chip">
              <input type="checkbox" name="allowedSkills" value="{{id}}" {{#if checked}}checked{{/if}} />
              <span>{{label}}</span>
            </label>
            {{/each}}
          </div>
        </fieldset>

        <fieldset class="mw-fieldset">
          <legend>Allowed Players</legend>
          {{#if hasPlayers}}
          <div class="mw-chiprow">
            {{#each playerOptions}}
            <label class="mw-chip">
              <input type="checkbox" name="allowedUserIds" value="{{id}}" {{#if checked}}checked{{/if}} />
              <span>{{name}}</span>
            </label>
            {{/each}}
          </div>
          {{else}}
          <p class="mw-empty">No active player users.</p>
          {{/if}}
        </fieldset>

        <fieldset class="mw-fieldset">
          <legend>Random Stock <small>auto-generated inventory</small></legend>
          <p class="mw-hint">Pick item types and/or rarities, choose how many to draw, then <strong>Generate Stock</strong> to roll random items from the item library into this merchant. Ammunition always stocks in full stacks of 20.</p>
          <div class="mw-pool">
            <div class="mw-pool__col">
              <span class="mw-field__label">Item Types</span>
              <div class="mw-chiprow">
                {{#each poolLootTypeOptions}}
                <label class="mw-chip mw-chip--sm">
                  <input type="checkbox" name="poolLootTypes" value="{{value}}" {{#if checked}}checked{{/if}} />
                  <span>{{label}}</span>
                </label>
                {{/each}}
              </div>
            </div>
            <div class="mw-pool__col">
              <span class="mw-field__label">Rarities</span>
              <div class="mw-chiprow">
                {{#each poolRarityOptions}}
                <label class="mw-chip mw-chip--sm">
                  <input type="checkbox" name="poolRarities" value="{{value}}" {{#if checked}}checked{{/if}} />
                  <span>{{label}}</span>
                </label>
                {{/each}}
              </div>
            </div>
          </div>
          <div class="mw-rarity-balance">
            <label class="mw-field mw-rarity-balance__preset">
              <span class="mw-field__label">Rarity Balance</span>
              <select class="mw-input" name="poolRarityBalance">
                {{#each poolRarityBalanceOptions}}
                <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
                {{/each}}
              </select>
            </label>
            <div class="mw-rarity-balance__grid" aria-label="Rarity multipliers">
              {{#each poolRarityWeightRows}}
              <label class="mw-rarity-balance__row mw-rarity-balance__row--{{rarity}}">
                <span>{{label}}</span>
                <input class="mw-input mw-input--num" type="number" name="poolRarityWeight.{{rarity}}" min="{{min}}" max="{{max}}" step="{{step}}" value="{{weight}}" />
              </label>
              {{/each}}
            </div>
          </div>
          <div class="mw-market">
            <div class="mw-market__head">
              <span class="mw-field__label">Item Value <small>(market tier or custom range)</small></span>
              <strong class="mw-market__range-label" data-pool-value-range>{{poolValueRangeLabel}}</strong>
            </div>
            <div class="mw-market__tiers">
              {{#each poolMarketTiers}}
              <button type="button" class="mw-market__tier {{#if active}}is-active{{/if}}" data-action="marketTier" data-min="{{min}}" data-max="{{max}}" title="{{label}} — {{#if max}}items up to {{max}} gp{{else}}no value limit{{/if}}">
                <i class="{{icon}}" aria-hidden="true"></i> {{label}}
              </button>
              {{/each}}
            </div>
            <div class="mw-market__range">
              <label class="mw-field mw-field--inline">
                <span class="mw-field__label">Min gp <small>(0 = none)</small></span>
                <input class="mw-input mw-input--num" type="number" name="poolMinGp" min="0" step="50" value="{{poolMinGp}}" />
              </label>
              <label class="mw-field mw-field--inline">
                <span class="mw-field__label">Max gp <small>(0 = none)</small></span>
                <input class="mw-input mw-input--num" type="number" name="poolMaxGp" min="0" step="50" value="{{poolMaxGp}}" />
              </label>
            </div>
          </div>
          <div class="mw-pool__foot">
            <label class="mw-field mw-field--inline">
              <span class="mw-field__label">How many</span>
              <input class="mw-input mw-input--num" type="number" name="poolCount" min="1" max="50" step="1" value="{{poolCount}}" />
            </label>
            <button type="button" class="mw-btn mw-btn--primary" data-action="generateStock">
              <i class="fa-solid fa-dice" aria-hidden="true"></i> Generate Stock
            </button>
            <button type="button" class="mw-btn" data-action="regenerateStock" title="Clear all stock, then roll a fresh batch from the pool">
              <i class="fa-solid fa-arrows-rotate" aria-hidden="true"></i> Re-Generate
            </button>
          </div>
        </fieldset>

        <fieldset class="mw-fieldset mw-fieldset--inv">
          <legend>Inventory <small>({{selected.items.length}} {{#if selected.itemCountIsOne}}row{{else}}rows{{/if}})</small></legend>
          {{#if inventoryRows.length}}
          <div class="mw-inv__search">
            <i class="fa-solid fa-magnifying-glass" aria-hidden="true"></i>
            <input type="search" class="mw-input" data-inv-search placeholder="Filter inventory…" aria-label="Filter inventory by item name" />
            <span class="mw-inv__search-count" data-inv-search-count aria-live="polite"></span>
          </div>
          {{/if}}
          <div class="mw-inv__head">
            <span>Item</span>
            <span>Qty</span>
            <span>Start</span>
            <span>Override gp</span>
            <span class="mw-inv__head-flag">∞</span>
            <span></span>
          </div>
          <div class="mw-inv__drop" data-drop-zone="inventory">
            {{#if inventoryRows.length}}
              {{#each inventoryRows}}
              <div class="mw-inv__row {{#if rarity}}mw-inv__row--{{rarity}}{{/if}} {{#if missing}}is-missing{{/if}} {{#if outOfStock}}is-out{{/if}}" data-uuid="{{uuid}}" data-search-text="{{name}}{{#if rarityLabel}} {{rarityLabel}}{{/if}}" title="Double-click to open sheet">
                <div class="mw-inv__name">
                  <span class="mw-inv__icon" style="background-image:url('{{img}}');" aria-hidden="true"></span>
                  <div class="mw-inv__copy">
                    <strong>{{name}}</strong>
                    <span class="mw-inv__meta">{{#unless missing}}<i class="fa-solid fa-coins mw-coin" aria-hidden="true"></i> {{/unless}}{{basePriceLabel}}{{#if rarityLabel}} · <span class="mw-rarity mw-rarity--{{rarity}}">{{rarityLabel}}</span>{{/if}}{{#if missing}} · <em>missing</em>{{/if}}</span>
                  </div>
                </div>
                <input class="mw-input mw-input--num" type="number" data-role="invQty" data-uuid="{{uuid}}" value="{{qtyDisplay}}" min="0" step="1" {{#if unlimited}}disabled{{/if}} />
                <input class="mw-input mw-input--num" type="number" data-role="invStartQty" data-uuid="{{uuid}}" value="{{startingQty}}" min="0" step="1" />
                <input class="mw-input mw-input--num" type="number" data-role="invPriceOverride" data-uuid="{{uuid}}" value="{{priceOverrideDisplay}}" min="0" step="0.05" placeholder="—" />
                <label class="mw-toggle">
                  <input type="checkbox" data-role="invUnlimited" data-uuid="{{uuid}}" {{#if unlimited}}checked{{/if}} />
                </label>
                <button type="button" class="mw-btn mw-btn--ghost mw-btn--icon" data-action="invRemove" data-uuid="{{uuid}}" title="Remove from inventory">
                  <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                </button>
              </div>
              {{/each}}
            {{else}}
              <p class="mw-empty">Drag items from the sidebar / item library here, or click <strong>Add From Library</strong>.</p>
            {{/if}}
          </div>
          <div class="mw-inv__actions">
            <button type="button" class="mw-btn" data-action="addFromPack">
              <i class="fa-solid fa-box-open" aria-hidden="true"></i> Add From Library
            </button>
            <button type="button" class="mw-btn" data-action="restock">
              <i class="fa-solid fa-arrows-rotate" aria-hidden="true"></i> Restock All
            </button>
            <button type="button" class="mw-btn mw-btn--danger" data-action="clearInventory">
              <i class="fa-solid fa-trash-can" aria-hidden="true"></i> Clear All
            </button>
          </div>
        </fieldset>

        <div class="mw-form__foot">
          <div class="mw-form__foot-left">
            <button type="button" class="mw-btn mw-btn--danger" data-action="deleteMerchant">
              <i class="fa-solid fa-trash" aria-hidden="true"></i> Delete Merchant
            </button>
          </div>
          <div class="mw-form__foot-right">
            <button type="button" class="mw-btn" data-action="duplicateMerchant" title="Create a copy of this merchant with an empty inventory">
              <i class="fa-solid fa-copy" aria-hidden="true"></i> Duplicate
            </button>
            <button type="button" class="mw-btn" data-action="save">
              <i class="fa-solid fa-floppy-disk" aria-hidden="true"></i> Save
            </button>
            <button type="button" class="mw-btn" data-action="previewSession" title="Open a sandbox shop window to see how buying, selling, and bargaining work — nothing real changes">
              <i class="fa-solid fa-eye" aria-hidden="true"></i> Preview
            </button>
            <button type="button" class="mw-btn mw-btn--primary" data-action="openSession" {{#unless canOpenSession}}disabled{{/unless}}>
              <i class="fa-solid fa-store" aria-hidden="true"></i> Open Session
            </button>
          </div>
        </div>

        {{#if activeSessions.length}}
        <div class="mw-sessions">
          <h4>Active Sessions</h4>
          <ul>
            {{#each activeSessions}}
            <li>
              <span>{{userLabel}}</span>
              <button type="button" class="mw-btn mw-btn--ghost" data-action="closeSession" data-session-id="{{sessionId}}">
                <i class="fa-solid fa-power-off" aria-hidden="true"></i> Close
              </button>
            </li>
            {{/each}}
          </ul>
        </div>
        {{/if}}
      </form>
      {{else}}
      <div class="mw-edit__empty">
        <i class="fa-solid fa-shop-lock" aria-hidden="true"></i>
        <p>Select a merchant from the list, or create one to get started.</p>
      </div>
      {{/if}}
    </section>
  </div>
</div>
